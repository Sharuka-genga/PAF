# Neon PostgreSQL connection
# Get these from: https://console.neon.tech → your project → Connection Details
NEON_DB_URL=
NEON_DB_USER=
NEON_DB_PASS=

# App Configuration
APP_JWT_SECRET=
APP_JWT_EXPIRATION_MS=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
FILE_UPLOAD_DIR=uploads

# Google OAuth2 Configuration
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin Secret Key (change in production)
APP_AUTH_ADMIN_SECRET_KEY=

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=